<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employees</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/employees/dashboard" class="brand-link">
            <img src="/media/Kainos_logo_1024X512-1643380451515.webp" alt="Kainos Logo" class="brand-logo">
          </a>
        </div>
        <ul class="navbar-menu">
          <li><a href="/employees/dashboard">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
          <li><a href="/roles">Job Roles</a></li>
        </ul>
        <% if (user) { %>
          <form action="/users/logout" method="post" style="margin-left:16px; display:inline-block;">
            <button type="submit" class="button">Logout</button>
          </form>
        <% } %>
      </div>
    </nav>
    <main>
      <section class="hero">
        <h1>Kainos Employee List</h1>
        <p>Browse and manage current employees.</p>
      </section>
    <section class="feature-card">
<table>
      <thead>
        <tr>
          <th>Employee Number</th>
          <th>Name</th>
          <th>Address</th>
          <th>Salary</th>
          <th>Role</th>
          <th class = "actions-header" colspan="3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% employees.forEach(employee => { %>
          <tr>
            <td><%= employee.employeeNumber %></td>
            <td><%= employee.name %></td>
            <td><%= employee.address %></td>
            <td>£<%= employee.salary.toLocaleString() %></td>
            <td><%= employee.role %></td>
            <td>
              <form action="/employees/delete/<%= employee.id %>" method="post">
                <button class="button" onclick="return confirm('Are you sure you want to delete <%= employee.name %>?')">
                  Delete
                </button>
              </form>

            </td>
            <td><a href="/employees/update/<%= employee.id %>" class="button">Edit</a></td>
            <td><a href="/employees/<%= employee.id %>" class="button">View</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="center-wrapper">
      <div class="hero-buttons" style="margin-top: 20px; justify-content: flex-start;">
        <a href="/employees/add" class="button">Create New Employee</a>
      </div>
    </div>
    </section>

    </main>
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Kainos</h3>
            <p>Digital transformation and software engineering solutions.</p>
          </div>
          <div class="footer-section">
            <h3>Contact</h3>
            <ul>
              <li>Email: <a href="mailto:info@kainos.com">info@kainos.com</a></li>
              <li>Phone: <a href="tel:+442890490490">+44 (0)28 9049 0490</a></li>
              <li>Address: Unit 4000, DBC, 120 Midsummer Boulevard, Milton Keynes MK9 2EA</li>
            </ul>
          </div>
          <div class="footer-section">
            <h3>Follow Us</h3>
            <ul>
              <li><a href="#">LinkedIn</a></li>
              <li><a href="#">Twitter</a></li>
              <li><a href="#">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Kainos Software. All rights reserved.</p>
        </div>
      </div>
    </footer>
    </form> 


  </body>
</html>
