<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employees</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23662D91' width='100' height='100'/><text x='50' y='65' font-size='70' font-weight='bold' fill='%2300B7FF' text-anchor='middle' font-family='Arial'>K</text></svg>">
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/" class="brand-link">
            <span class="brand-logo">K</span>
            <span class="brand-text">KAINOS</span>
          </a>
        </div>
        <ul class="navbar-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
        </ul>
      </div>
    </nav>
    <main>
      <h1>Kainos Employees</h1>
    <table>
      <thead>
        <tr>
          <th>Employee Number</th>
          <th>Name</th>
          <th>Address</th>
          <th>Salary</th>
          <th>Role</th>
          <th></th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% employees.forEach(employee => { %>
          <tr>
            <td><%= employee.employeeNumber %></td>
            <td><%= employee.name %></td>
            <td><%= employee.address %></td>
            <td>£<%= employee.salary.toLocaleString() %></td>
            <td><%= employee.role %></td>
            <td>
              <form action="/employees/delete/<%= employee.id %>" method="post">
                <input type="submit" value="Delete" onclick="return confirm('Are you sure you want to delete <%= employee.name %>?')">
              </form>
            </td>
            <td><a href="/employees/update/<%= employee.employeeNumber %>">Edit</a></td>
            <td><a href="/employees/<%= employee.employeeNumber %>">View</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

      <form action="/employees/add" method="get">
        <input type="submit" value="Create New Employee">
      </form>
    </main>
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Kainos</h3>
            <p>Digital transformation and software engineering solutions.</p>
          </div>
          <div class="footer-section">
            <h3>Contact</h3>
            <ul>
              <li>Email: <a href="mailto:info@kainos.com">info@kainos.com</a></li>
              <li>Phone: <a href="tel:+442890490490">+44 (0)28 9049 0490</a></li>
              <li>Address: Unit 4000, DBC, 120 Midsummer Boulevard, Milton Keynes MK9 2EA</li>
            </ul>
          </div>
          <div class="footer-section">
            <h3>Follow Us</h3>
            <ul>
              <li><a href="#">LinkedIn</a></li>
              <li><a href="#">Twitter</a></li>
              <li><a href="#">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Kainos Software. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
