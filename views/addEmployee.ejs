<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Employee</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23662D91' width='100' height='100'/><text x='50' y='65' font-size='70' font-weight='bold' fill='%2300B7FF' text-anchor='middle' font-family='Arial'>K</text></svg>">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/dashboard" class="brand-link">
            <img src="/media/Kainos_logo_1024X512-1643380451515.webp" alt="Kainos Logo" class="brand-logo">
          </a>
        </div>
        <ul class="navbar-menu">
          <li><a href="/dashboard">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
          <li><a href="/roles">Job Roles</a></li>
        </ul>
      </div>
    </nav>
    <main>
      <h1>Add New Employee</h1>

    <form action="/employees/add" method="post">
        <label for="name">Name:</label><br>
        <input type="text" id="name" name="name" required><br>

        <label for="address">Address:</label><br>
        <input type="text" id="address" name="address" required><br>

        <label for="salary">Salary:</label><br>
        <input type="number" min="0" id="salary" name="salary" required><br>

        <label for="role">Role:</label><br>
        <select id="role" name="role" required>
          <option value="">-- Select a role --</option>
          <% jobRoles.forEach(jobRole => { %>
            <option value="<%= jobRole.name %>" <%= (formData && formData.role === jobRole.name) ? 'selected' : '' %>><%= jobRole.name %></option>
          <% }) %>
        </select><br>


        <input type="submit" value="Submit">
    </form>
    </main>
