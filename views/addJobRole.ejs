<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Job Role</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/employees/dashboard" class="brand-link">
            <img src="/media/Kainos_logo_1024X512-1643380451515.webp" alt="Kainos Logo" class="brand-logo">
          </a>
        </div>

        <ul class="navbar-menu">
          <li><a href="/employees/dashboard">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
          <li><a href="/roles">Job Roles</a></li>
        </ul>

        <% if (user) { %>
          <form action="/users/logout" method="post" style="margin-left:16px; display:inline-block;">
            <button type="submit" class="button">Logout</button>
          </form>
        <% } %>
      </div>
    </nav>

    <main>
      <h1>Add New Job Role</h1>

      <form action="/roles/job-role" method="post">
          <label for="name">Name:</label><br>
          <input type="text" id="name" name="name" required><br>

          <label for="level">Level:</label><br>
          <input type="text" id="level" name="level" required><br>

          <label for="capability">Capability:</label><br>
          <input type="text" id="capability" name="capability" required><br>

          <label for="description">Description:</label><br>
          <textarea id="description" name="description" required></textarea><br>

          <input type="submit" value="Create Job Role">
      </form>

      <br>
      <a href="/roles" class="button">Back to Job Roles</a>
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Kainos</h3>
            <p>Digital transformation and software engineering solutions.</p>
          </div>
          <div class="footer-section">
            <h3>Contact</h3>
            <ul>
              <li>Email: <a href="mailto:info@kainos.com">info@kainos.com</a></li>
              <li>Phone: <a href="tel:+442890490490">+44 (0)28 9049 0490</a></li>
              <li>Address: Unit 4000, DBC, 120 Midsummer Boulevard, Milton Keynes MK9 2EA</li>
            </ul>
          </div>
          <div class="footer-section">
            <h3>Follow Us</h3>
            <ul>
              <li><a href="#">LinkedIn</a></li>
              <li><a href="#">Twitter</a></li>
              <li><a href="#">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Kainos Software. All rights reserved.</p>
        </div>
      </div>
    </footer>
</body>
</html>
