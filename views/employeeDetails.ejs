<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Details</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/employees/dashboard" class="brand-link">
            <img src="/media/Kainos_logo_1024X512-1643380451515.webp" alt="Kainos Logo" class="brand-logo">
          </a>
        </div>
        <ul class="navbar-menu">
          <li><a href="/employees/dashboard">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
          <li><a href="/roles">Job Roles</a></li>
        </ul>
        <% if (user) { %>
          <form action="/users/logout" method="post" style="margin-left:16px; display:inline-block;">
            <button type="submit" class="button">Logout</button>
          </form>
        <% } %>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <% if(!employee) { %>
        <section class="hero">
          <h1>Employee Not Found</h1>
          <p>The employee you're looking for doesn't exist.</p>
          <div class="hero-buttons">
            <a href="/employees" class="button">Back to Employees</a>
          </div>
        </section>
      <% } else { %>
        <section class="hero">
          <h1><%= employee.name %></h1>
          <p>Employee Details</p>
        </section>

        <section class="feature-card">
          <h2>Employee Information</h2>
          <table>
            <thead>
              <tr>
                <th>Field</th>
                <th>Value</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Name</td>
                <td><%= employee.name %></td>
              </tr>
              <tr>
                <td>Address</td>
                <td><%= employee.address %></td>
              </tr>
              <tr>
                <td>Salary</td>
                <td>£<%= employee.salary.toLocaleString() %></td>
              </tr>
              <tr>
                <td>Role</td>
                <td><%= employee.role %></td>
              </tr>
              <tr>
                <td>Employee Number</td>
                <td><%= employee.employeeNumber %></td>
              </tr>
            </tbody>
          </table>

          <div class="hero-buttons">
            <a href="/employees" class="button">Back to List</a>
            <a href="/employees/update/<%= employee.id %>" class="button">Edit Employee</a>
          </div>
        </section>
      <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Kainos</h3>
            <p>Digital transformation and software engineering solutions.</p>
          </div>
          <div class="footer-section">
            <h3>Contact</h3>
            <ul>
              <li>Email: <a href="mailto:info@kainos.com">info@kainos.com</a></li>
              <li>Phone: <a href="tel:+442890490490">+44 (0)28 9049 0490</a></li>
              <li>Address: Unit 4000, DBC, 120 Midsummer Boulevard, Milton Keynes MK9 2EA</li>
            </ul>
          </div>
          <div class="footer-section">
            <h3>Follow Us</h3>
            <ul>
              <li><a href="#">LinkedIn</a></li>
              <li><a href="#">Twitter</a></li>
              <li><a href="#">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Kainos Software. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>