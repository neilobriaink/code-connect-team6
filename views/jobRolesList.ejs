<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Roles</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-brand">
          <a href="/employees/dashboard" class="brand-link">
            <img src="/media/Kainos_logo_1024X512-1643380451515.webp" alt="Kainos Logo" class="brand-logo">
          </a>
        </div>
        <ul class="navbar-menu">
          <li><a href="/employees/dashboard">Home</a></li>
          <li><a href="/employees">Employees</a></li>
          <li><a href="/users">Users</a></li>
          <li><a href="/roles">Job Roles</a></li>
        </ul>
        <% if (user) { %>
          <form action="/users/logout" method="post" style="margin-left:16px; display:inline-block;">
            <button type="submit" class="button">Logout</button>
          </form>
        <% } %>
      </div>
    </nav>

    <main>
      <section class="hero">
        <h1>Kainos Job Roles</h1>
        <p>Browse and manage job roles in your recruitment dashboard.</p>
      </section>

      <% if(!roles || roles.length === 0){ %>
        <section class="feature-card">
          <h2>No Job Roles Available</h2>
          <p>Use the button below to add a new job role.</p>
          <div class="hero-buttons">
            <a href="/roles/job-role" class="button">Create New Job Role</a>
          </div>
        </section>
      <% } else { %>
        <section class="feature-card">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Level</th>
                <th>Capability</th>
                <th>Description</th>
                <th colspan="2">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% roles.forEach(role => { %>
                <tr>
                  <td><%= role.name %></td>
                  <td><%= role.level %></td>
                  <td><%= role.capability %></td>
                  <td><%= role.description %></td>
                  <td><a href="/roles/job-role-edit/<%= role.id %>" class="button">Edit</a></td>
                  <td><a href="/roles/job-role-delete/<%= role.id %>" class="button">Delete</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
    <div class="center-wrapper">
          <div class="hero-buttons" style="margin-top: 20px; justify-content: flex-start;">
            <a href="/roles/job-role" class="button">Create New Job Role</a>
          </div>
    </div>

        </section>
      <% } %>
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Kainos</h3>
            <p>Digital transformation and software engineering solutions.</p>
          </div>
          <div class="footer-section">
            <h3>Contact</h3>
            <ul>
              <li>Email: <a href="mailto:info@kainos.com">info@kainos.com</a></li>
              <li>Phone: <a href="tel:+442890490490">+44 (0)28 9049 0490</a></li>
              <li>Address: Unit 4000, DBC, 120 Midsummer Boulevard, Milton Keynes MK9 2EA</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h3>Follow Us</h3>
            <ul>
              <li><a href="#">LinkedIn</a></li>
              <li><a href="#">Twitter</a></li>
              <li><a href="#">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Kainos Software. All rights reserved.</p>
        </div>
      </div>
    </footer>
</body>
</html>